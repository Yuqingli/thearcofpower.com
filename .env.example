# Google Analytics 4 Measurement ID
# Get from: Analytics Admin → Property → Data Streams → Web → Measurement ID
# Format: G-XXXXXXXXXX
# This value is embedded in client-side JS at build time (NEXT_PUBLIC_* prefix).
# For CI/CD, set as a repository variable in GitHub Actions (not a secret — it's public anyway).
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
