#!/bin/bash
# Canonical pre-push hook for blog articles.
# Shared across: ComputeLeap, AgentConn, The Arc of Power.
# Each site's .git/hooks/pre-push (and Arc's .githooks/pre-push) should be an
# identical copy of this file — re-sync after any change here.
#
# Behavior:
#   - Scans CHANGED articles in the latest commit (HEAD~1..HEAD).
#   - Skips validation for articles already published on the upstream branch
#     (avoids forcing gate compliance on edits to legacy articles).
#   - New articles: runs ~/.openclaw/workspace/scripts/validate-article.sh.
#   - Blocks push if any new article fails.

CHANGED_ARTICLES=$(git diff --name-only HEAD~1 HEAD 2>/dev/null | grep -E "src/content/blog/.*\.(md|mdx)$")
if [ -z "$CHANGED_ARTICLES" ]; then exit 0; fi

VALIDATE="$HOME/.openclaw/workspace/scripts/validate-article.sh"
if [ ! -f "$VALIDATE" ]; then exit 0; fi

# Determine upstream branch (origin/main, origin/master, etc.)
REMOTE_BRANCH=$(git rev-parse --abbrev-ref @{upstream} 2>/dev/null || echo "origin/main")

FAILED=false
for f in $CHANGED_ARTICLES; do
  [ ! -f "$f" ] && continue
  SLUG=$(basename "$f" | sed 's/\.mdx$//;s/\.md$//')

  # Skip if already published on upstream (legacy articles escape the gate).
  if git cat-file -e "$REMOTE_BRANCH:$f" 2>/dev/null; then
    echo "⏭️  $SLUG: already published on $REMOTE_BRANCH — skipping validation"
    continue
  fi

  echo "🔍 Validating: $SLUG"
  RESULT=$("$VALIDATE" "$(git rev-parse --show-toplevel)/$f" 2>&1)
  if echo "$RESULT" | grep -q "❌ FAIL"; then
    echo "$RESULT"
    echo ""
    FAILED=true
  else
    echo "  ✅ PASS"
  fi
done

if [ "$FAILED" = true ]; then
  echo "❌ PUSH BLOCKED: New articles failed validation"
  exit 1
fi
exit 0
